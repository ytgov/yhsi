//- template.pug

style
     include ../styles.css
    
table.title-row
  tbody 
    tr 
      td
        div People information
      td
        div(style='width:200px;')
          include ../yukon.svg

div.grid
  table.grid-table
    thead
      tr 
        td 
          strong.underline Given Name 
        td 
          strong.underline Surname
        td 
          strong.underline Birth Year
        td 
          strong.underline Death Year
    tbody 
      each val in data
        tr 
          td #{val.GivenName} 
          td #{val.Surname} 
          td #{val.BirthYear}
          td #{val.DeathYear} 